# =====================================================
# ClawHub 环境配置文件示例
# 复制此文件为 .env 并根据实际情况修改
# =====================================================

# =====================================================
# 数据库配置 (PostgreSQL)
# =====================================================
POSTGRES_USER=clawhub
POSTGRES_PASSWORD=clawhub_secret
POSTGRES_DB=clawhub
POSTGRES_PORT=5432

# 完整的数据库连接 URL（后端使用）
# DATABASE_URL=postgresql+asyncpg://clawhub:clawhub_secret@localhost:5432/clawhub

# =====================================================
# Redis 缓存配置
# =====================================================
REDIS_PASSWORD=clawhub_redis_secret
REDIS_PORT=6379

# Redis 连接 URL
# REDIS_URL=redis://:clawhub_redis_secret@localhost:6379/0

# =====================================================
# MinIO 对象存储配置
# =====================================================
MINIO_ROOT_USER=clawhub
MINIO_ROOT_PASSWORD=clawhub_minio_secret
MINIO_BUCKET_NAME=clawhub-storage
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# =====================================================
# 后端服务配置
# =====================================================
BACKEND_PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# 安全密钥（生产环境必须修改！）
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS 允许的来源（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# =====================================================
# 前端配置
# =====================================================
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
VITE_MINIO_ENDPOINT=localhost:9000

# =====================================================
# Nginx 配置
# =====================================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# =====================================================
# 邮件服务配置（可选）
# =====================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@clawhub.io
SMTP_PASSWORD=your-smtp-password
SMTP_TLS=true

# =====================================================
# 第三方认证配置（可选）
# =====================================================
# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# GitLab OAuth
GITLAB_CLIENT_ID=your-gitlab-client-id
GITLAB_CLIENT_SECRET=your-gitlab-client-secret

# =====================================================
# 容器镜像仓库配置（可选）
# =====================================================
REGISTRY_STORAGE_BACKEND=s3
REGISTRY_STORAGE_S3_REGION=us-east-1
REGISTRY_STORAGE_S3_BUCKET=clawhub-registry

# =====================================================
# 监控和日志（可选）
# =====================================================
SENTRY_DSN=
PROMETHEUS_ENABLED=false
GRAFANA_ADMIN_PASSWORD=admin
