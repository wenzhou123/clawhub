# ClawHub Frontend Dockerfile (Simple version)
FROM node:20-alpine

# Install dependencies
RUN npm install -g pnpm

# Set work directory
WORKDIR /app

# Copy package files
COPY package.json ./

# Install dependencies
RUN pnpm install

# Copy application code
COPY . .

# Expose port
EXPOSE 5173

# Run command
CMD ["pnpm", "run", "dev", "--", "--host", "0.0.0.0"]
